{
   "datareader": {
      "datapath": "./images",
      "maxim": -1
   },

   "classifier":{
	   "type": "cnn",
	   "modeltype" : "config/default128",
	   "labelFile" : "./models_save/HierarchicalLabels3L_13052025.pkl",
	   "labelFileV3" : "./models_save/HierarchicalLabels3L_RES_V3_05092025.pkl",
	   "labelFileV5" : "./models_save/HierarchicalLabels3L_RES_V5_05092025.pkl",
	   "labelFileV6" : "./models_save/HierarchicalLabels3L_RES_V6.pkl",
       "species": ["Coccinellidae", "Coleoptera", "Background", "Bombus", "Syrphidae", "Lepidoptera", "Araneae", "Formidicidae", "Diptera", "Hemiptera", 
                  "Isopoda", "Unspecified", "Hymenoptera", "Orthoptera", "Rhagnoycha fulva", "Satyrinae", "Aglais urticea", "Odonata", "Apis mellifera"],
       "imagedimension": 224,
	   "threshold_unknown": 10,
	   "unknown_dir": "unknowns",
       "write_unknown" : false,
       "boundingboxpadding": 100
   },

   "blobdetector":{
      "type": "adaptive",
      "adapthres": false,
      "adaptive": {
         "medianblur": 5,
         "adapsize": 801,
         "adapconst": 8,
         "kernel": 20
      },
      "simple": {
         "kernel": 7,
         "thresh": 192
      },
    	"otsu": {
    	   "blur_kernel": 3,
    	   "blur": 7,
    	   "morph_kernel": 11
      }, 
      "custom": {
         "kernel": 7,
         "thresh": 5
      },           
      "minarea": 12000,
      "maxarea": 250000,
      "backgroundpath": "./config/sample_background.jpg"
   },

   "tracker":{
      "distance_cost_weight": 1.3,
      "area_cost_weight": 0.7,
      "cost_threshold": 0.6,
	  "maxage": 5,
	  "_comment": 50,
	  "maxtimesec": 30 
   },

   "moviemaker":{
      "maxframes": -1,
      "maximages": -1,
      "resultdir": "./tracks",
      "writeimages": false,
      "writemovie": true,
      "moviesize": false,
      "fps":1
   },
   
   "stats":{
     "mincounts": 2
   }
}
